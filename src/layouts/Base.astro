---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Triple Helix Robotics",
  description = "The award-winning Newport News competitive robotics team",
} = Astro.props;

const pageTitle =
  title === "Triple Helix Robotics"
    ? title
    : `${title} | Triple Helix Robotics`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link
      rel="icon"
      type="image/png"
      href={`${import.meta.env.BASE_URL}favicon.png`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <!-- Alpine.js for nav toggle and other lightweight interactivity -->
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"
    ></script>
  </head>
  <body class="font-sans text-gray-900 bg-white">
    <slot />

    <!-- Back to top button (mobile only, appears when scrolling up) -->
    <div
      x-data="{ show: false, last: 0, onScroll() { const y = window.scrollY; if (y < this.last - 5) this.show = y > 200; else if (y > this.last + 40) this.show = false; this.last = y; } }"
      @scroll.window.passive="onScroll()"
      x-show="show"
      x-transition
      class="md:hidden fixed bottom-6 right-6 z-50"
    >
      <button
        @click="window.scrollTo({ top: 0, behavior: 'smooth' }); $event.currentTarget.blur()"
        class="bg-gold text-white rounded-full w-12 h-12 flex items-center justify-center shadow-lg active:bg-yellow-400 transition-colors"
        aria-label="Back to top"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 15l7-7 7 7"></path>
        </svg>
      </button>
    </div>
  </body>
</html>
