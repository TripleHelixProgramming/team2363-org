---
// Recruitment call-to-action at the bottom of the home page.
// Edit this file to change the joining text or link destination.
---

<section id="join" class="py-16 px-4 bg-white">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-purple mb-4">Interested in joining?</h2>
    <p class="text-gray-600 mb-4 max-w-lg mx-auto">
      Great! We need your contribution to the team, even if you don&rsquo;t want
      to build robots, or even if you don&rsquo;t have any prior experience.
    </p>
    <a
      href={`${import.meta.env.BASE_URL}contact/`}
      class="inline-block border-2 border-purple text-purple font-bold px-6 py-3 rounded hover:bg-purple hover:text-white transition-colors"
    >
      Get in touch &rarr;
    </a>
  </div>
</section>
