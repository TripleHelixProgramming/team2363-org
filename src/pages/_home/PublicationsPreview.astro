---
import { getCollection } from "astro:content";
import Carousel from "../../components/Carousel.astro";
import PublicationCard from "../../components/PublicationCard.astro";
import { sortPublications } from "../../utils/publications";
import { btn, h2 } from "../../utils/classes";

const allPublications = await getCollection("publications");
const latestPublications = sortPublications(allPublications)
  .reverse()
  .slice(0, 6);
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class={`${h2} text-center`}>Our latest publications</h2>
    {
      latestPublications.length > 0 ? (
        <Carousel
          prevLabel="Previous publications"
          nextLabel="Next publications"
        >
          {latestPublications.map((pub) => (
            <PublicationCard pub={pub} />
          ))}
        </Carousel>
      ) : (
        <p class="text-gray-500">No publications yet.</p>
      )
    }
    <div class="mt-8 text-center">
      <a href={`${import.meta.env.BASE_URL}publications/`} class={btn}>
        See all publications
      </a>
    </div>
  </div>
</section>
