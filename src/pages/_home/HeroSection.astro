---
import { getImage } from "astro:assets";
import heroSrc from "../hero.jpg";

const hero = await getImage({ src: heroSrc, format: "webp" });
---

<section
  class="relative bg-purple text-white py-32 px-4 text-center"
  style={`background-image: url('${hero.src}'); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-purple/70"></div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold mb-4">Triple Helix Robotics</h1>
    <p class="text-xl md:text-2xl text-gray-200 mb-8">
      The award-winning Newport News competitive robotics team
    </p>
    <a
      href="#about"
      class="inline-block bg-gold text-purple font-bold px-8 py-3 rounded hover:bg-yellow-400 transition-colors"
    >
      Learn more
    </a>
  </div>
</section>
