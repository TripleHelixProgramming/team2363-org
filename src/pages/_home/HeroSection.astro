---
import { getImage } from "astro:assets";
import heroSrc from "../hero.jpg";

const hero = await getImage({ src: heroSrc, format: "webp" });
---

<section
  class="relative bg-purple text-white py-40 pb-28 px-4 text-center -mt-16 pt-36"
  style={`background-image: url('${hero.src}'); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-purple/30"></div>
  <div class="relative z-10 max-w-3xl mx-auto">
    <img
      src={`${import.meta.env.BASE_URL}THR-logo-full-colors.svg`}
      alt="Triple Helix Robotics"
      class="mx-auto mb-8 w-[28rem] md:w-[36rem]"
    />
    <p class="text-xl md:text-2xl text-gray-200 mb-8">
      The award-winning Newport News competitive robotics team
    </p>
    <a
      href="#about"
      class="inline-block bg-gold text-white font-bold px-8 py-3 rounded hover:bg-yellow-400 transition-colors"
    >
      Learn more
    </a>
  </div>
</section>
