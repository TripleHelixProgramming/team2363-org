---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Carousel from "../../components/Carousel.astro";
import sponsorsData from "../partners/sponsors.json";
import { btn, h2Cta } from "../../utils/classes";

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  "../partners/sponsor-logos/*.{png,jpg,jpeg,webp,svg}",
  { eager: true },
);
function getLogo(filename: string): ImageMetadata | undefined {
  return logoModules[`../partners/sponsor-logos/${filename}`]?.default;
}
const sponsors = sponsorsData.tiers
  .flatMap((t) => t.sponsors)
  .filter((s) => getLogo(s.logo));
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class={`${h2Cta} text-center`}>Who makes it possible?</h2>
    <p class="text-gray-600 mb-6 text-center">
      We are grateful to our sponsors and partners for making Triple Helix
      possible.
    </p>
    <Carousel
      scrollAmount={376}
      prevLabel="Previous sponsors"
      nextLabel="Next sponsors"
    >
      {
        sponsors.map((s) => {
          const logo = getLogo(s.logo)!;
          return (
            <div
              title={s.name}
              class="shrink-0 snap-start flex items-center justify-center w-[22rem] h-48 bg-white rounded-lg border-2 border-gray-200 shadow-md p-4"
            >
              <Image
                src={logo}
                alt={s.name}
                class="max-w-full max-h-full object-contain"
              />
            </div>
          );
        })
      }
    </Carousel>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href={`${import.meta.env.BASE_URL}partners/`} class={btn}>
        See all our partners
      </a>
      <a href={`${import.meta.env.BASE_URL}support/`} class={btn}>
        Learn how you can support us
      </a>
      <a
        href="https://www.paypal.com/donate?hosted_button_id=R9BJ2TLELQR6W"
        target="_blank"
        rel="noopener noreferrer"
        class={btn}
      >
        Donate now
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>
