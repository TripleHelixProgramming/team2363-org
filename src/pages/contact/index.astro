---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { Icon } from "astro-icon/components";

const contactEmail = "contact@team2363.org";
---

<Base
  title="Contact — Triple Helix Robotics"
  description="Get in touch with Triple Helix Robotics, join the team, or sign up for updates."
>
  <Nav />

  <main class="max-w-6xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-navy-dark mb-2">Get in touch</h1>
    <p class="text-gray-600 mb-10">
      Questions about the team, sponsorship, or joining? Reach out below.
    </p>

    <div class="grid gap-6 md:grid-cols-2">

      <!-- 1. Send us a message -->
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <div class="flex items-center gap-2 mb-4">
          <Icon name="lucide:mail" class="w-5 h-5 text-gold shrink-0" aria-hidden="true" />
          <h2 class="font-bold text-navy">Send us a message</h2>
        </div>
        <form action="https://formspree.io/f/mvznwnng" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
              Name <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              id="name"
              type="text"
              name="name"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              Email <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              id="email"
              type="email"
              name="email"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy"
            >
              <option value="General inquiry">General inquiry</option>
              <option value="Joining the team">Joining the team</option>
              <option value="Sponsorship / partnership">Sponsorship / partnership</option>
              <option value="Media / press">Media / press</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
              Message <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-navy-dark text-white font-bold px-6 py-2 rounded hover:bg-navy transition-colors"
          >
            Send message
          </button>
        </form>
      </div>

      <!-- 2. Drop by our next meeting -->
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm flex flex-col">
        <iframe
          src="https://www.google.com/maps?q=11516+Jefferson+Ave,+Newport+News,+VA+23601&amp;output=embed"
          class="w-full h-52 border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Peninsula STEM Gym location"
        ></iframe>
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-3">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-gold shrink-0" aria-hidden="true" />
            <h2 class="font-bold text-navy">Drop by our next meeting</h2>
          </div>
          <p class="text-sm text-gray-600 mb-4">
            We typically meet Tuesday and Thursday evenings, 6–9 pm at the
            <a
              href="https://maps.app.goo.gl/Y2VosW3wmbiVZwp48"
              target="_blank"
              rel="noopener noreferrer"
              class="text-navy hover:text-gold transition-colors"
            >Peninsula STEM Gym</a> in central Newport News, VA.
            We invite you to swing by and meet the team!
          </p>
          <a
            href="http://calendar.team2363.org"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-navy hover:text-gold transition-colors mt-auto"
          >
            <Icon name="lucide:calendar" class="w-4 h-4 shrink-0" aria-hidden="true" />
            Check the team calendar →
          </a>
        </div>
      </div>

      <!-- 3. Read our team handbook -->
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm flex flex-col">
        <!-- TODO: replace this placeholder with a handbook cover image saved to public/ or co-located here -->
        <div class="bg-gray-100 h-52 flex items-center justify-center text-gray-400 text-sm">
          Handbook cover image — coming soon
        </div>
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-2 mb-3">
            <Icon name="lucide:book-open" class="w-5 h-5 text-gold shrink-0" aria-hidden="true" />
            <h2 class="font-bold text-navy">Read our team handbook</h2>
          </div>
          <p class="text-sm text-gray-600 mb-4">
            Our handbook covers everything you need to know: expectations, how to join, what
            to bring, and how the season works.
          </p>
          <a
            href="http://handbook.team2363.org"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-navy hover:text-gold transition-colors mt-auto"
          >
            <Icon name="lucide:external-link" class="w-4 h-4 shrink-0" aria-hidden="true" />
            Open handbook →
          </a>
        </div>
      </div>

      <!-- 4. Stay in the loop -->
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <div class="flex items-center gap-2 mb-4">
          <Icon name="lucide:bell" class="w-5 h-5 text-gold shrink-0" aria-hidden="true" />
          <h2 class="font-bold text-navy">Stay in the loop</h2>
        </div>
        <p class="text-sm text-gray-600 mb-4">
          Sign up to receive periodic updates about our events, projects, and accomplishments.
        </p>
        <form
          action="https://iifound.us13.list-manage.com/subscribe/post?u=067106645ad3d8a90f50ba5ef&amp;id=ee992f1659&amp;v_id=47&amp;f_id=00216ce1f0"
          method="post"
          id="mc-embedded-subscribe-form"
          name="mc-embedded-subscribe-form"
          target="_self"
          novalidate
          class="space-y-4"
        >
          <div>
            <label for="mce-EMAIL" class="block text-sm font-medium text-gray-700 mb-1">
              Email address <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              name="EMAIL"
              id="mce-EMAIL"
              required
              class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy"
            />
          </div>
          <!-- GDPR consent -->
          <fieldset class="border-0 p-0 m-0 space-y-2">
            <label class="flex items-start gap-2 cursor-pointer text-sm text-gray-600">
              <input
                type="checkbox"
                id="gdpr_49965"
                name="gdpr[49965]"
                value="Y"
                required
                class="mt-0.5 shrink-0"
              />
              <span>I agree to receive team updates and news. I can unsubscribe at any time.</span>
            </label>
            <p class="text-xs text-gray-400">
              We use Mailchimp to send emails. By subscribing, your information will be transferred
              to Mailchimp for processing. <a
                href="https://mailchimp.com/legal/terms"
                target="_blank"
                rel="noopener noreferrer"
                class="underline hover:text-navy transition-colors">Learn more</a
              >.
            </p>
          </fieldset>
          <!-- Mailchimp response messages -->
          <div id="mce-responses">
            <div id="mce-error-response" style="display:none"></div>
            <div id="mce-success-response" style="display:none"></div>
          </div>
          <!-- Anti-spam honeypot — do not remove -->
          <div aria-hidden="true" style="position:absolute;left:-5000px">
            <input
              type="text"
              name="b_067106645ad3d8a90f50ba5ef_ee992f1659"
              tabindex="-1"
              value=""
            />
          </div>
          <input type="hidden" name="tags" value="3690671" />
          <button
            type="submit"
            name="subscribe"
            id="mc-embedded-subscribe"
            class="bg-navy-dark text-white font-bold px-6 py-2 rounded hover:bg-navy transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>

    </div>
  </main>

  <Footer />
</Base>