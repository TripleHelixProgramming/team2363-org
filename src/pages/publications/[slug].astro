---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { sortPublications } from "../../utils/publications";

export async function getStaticPaths() {
  const publications = await getCollection("publications");
  const sorted = sortPublications(publications);
  return sorted.map((entry, i) => ({
    params: { slug: entry.id.replace(/\/index$/, "") },
    props: {
      entry,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, date, categories, links, thumbnail } = entry.data;
---

<Base title={title}>
  <Nav />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <!-- Back link -->
    <a
      href={`${import.meta.env.BASE_URL}publications/`}
      class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gold transition-colors mb-8"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      All publications
    </a>

    <!-- Thumbnail -->
    {
      thumbnail && (
        <Image
          src={thumbnail}
          alt=""
          class="w-full max-h-80 object-cover rounded-lg mb-8"
        />
      )
    }

    <!-- Header -->
    <div class="mb-8">
      <div class="flex flex-wrap gap-1 mb-3">
        {
          categories.map((cat) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">
              {cat}
            </span>
          ))
        }
      </div>
      <h1 class="text-3xl font-bold text-purple mb-2 leading-snug">
        {title}
      </h1>
      <p class="text-sm text-gray-400">
        {
          date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </p>
    </div>

    <!-- Body -->
    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- Links -->
    {
      links && links.length > 0 && (
        <div class="mt-10">
          <ul class="flex flex-wrap gap-3">
            {links.map(({ label, url }) => (
              <li>
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm font-medium text-watermelon hover:text-gold"
                >
                  {label}
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
    <!-- Prev / Next nav -->
    {
      (prev || next) && (
        <nav class="mt-12 pt-8 border-t border-gray-200 grid grid-cols-2 gap-4">
          <div>
            {prev && (
              <a
                href={`${import.meta.env.BASE_URL}publications/${prev.id.replace(/\/index$/, "")}/`}
                class="group flex flex-col gap-1"
              >
                <span class="text-xs text-gray-400 group-hover:text-gold transition-colors">
                  ← Older
                </span>
                <span class="text-sm font-medium text-gray-500 group-hover:text-gold transition-colors leading-snug">
                  {prev.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="text-right">
            {next && (
              <a
                href={`${import.meta.env.BASE_URL}publications/${next.id.replace(/\/index$/, "")}/`}
                class="group flex flex-col gap-1"
              >
                <span class="text-xs text-gray-400 group-hover:text-gold transition-colors">
                  Newer →
                </span>
                <span class="text-sm font-medium text-gray-500 group-hover:text-gold transition-colors leading-snug">
                  {next.data.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </main>

  <Footer />
</Base>

<style>
  .prose {
    color: #374151;
    line-height: 1.75;
  }
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: #233452;
    font-weight: 700;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }
  .prose :global(h1) {
    font-size: 1.75rem;
  }
  .prose :global(h2) {
    font-size: 1.35rem;
  }
  .prose :global(h3) {
    font-size: 1.15rem;
  }
  .prose :global(p) {
    margin-bottom: 1.5em;
  }
  .prose :global(a) {
    color: #ef2d56;
    text-decoration: underline;
  }
  .prose :global(a:hover) {
    color: #fdb813;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1em;
  }
  .prose :global(ul) {
    list-style-type: disc;
  }
  .prose :global(ol) {
    list-style-type: decimal;
  }
  .prose :global(li) {
    margin-bottom: 0.25em;
  }
  .prose :global(li p) {
    margin-bottom: 0;
  }
  .prose :global(strong) {
    font-weight: 700;
    color: #111827;
  }
  .prose :global(em) {
    font-style: italic;
  }
  .prose :global(blockquote) {
    border-left: 4px solid #fdb813;
    padding: 0.75rem 1rem;
    background: #f9fafb;
    border-radius: 0 0.25rem 0.25rem 0;
    color: #6b7280;
    margin: 1.5em 0;
  }
  .prose :global(img) {
    border-radius: 0.5rem;
    max-width: 100%;
    max-height: 600px;
    width: auto;
    height: auto;
    margin: 1.5em auto;
    display: block;
  }
  .prose :global(hr) {
    border-color: #e5e7eb;
    margin: 2em 0;
  }
  .prose :global(pre) {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1em;
  }
  .prose :global(code) {
    font-family: monospace;
    font-size: 0.9em;
    background: #f3f4f6;
    padding: 0.1em 0.3em;
    border-radius: 0.25rem;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }
</style>
