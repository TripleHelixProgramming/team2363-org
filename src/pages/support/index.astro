---
import { Icon } from "astro-icon/components";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { card, btn, link, h1, h2, h3 } from "../../utils/classes";

const sponsorshipTiers = [
  {
    name: "Visionary partners",
    level: "Elite level",
    amount: "$10,000+ annual contribution",
    icon: "lucide:gem",
    description:
      "Triple Helix celebrates our relationship with these strategic and founding partners by displaying the sponsoring organization's logo on the team's competition robot, the organization's name on team t-shirts, and the organization's name or logo on this website, along with a shout-out at competition and social media recognition.",
  },
  {
    name: "Innovation sponsors",
    level: "Premium level",
    amount: "$1,500+ annual contribution",
    icon: "lucide:lightbulb",
    description:
      "Triple Helix celebrates our relationship with these major sponsors by displaying the sponsoring organization's logo on the team's FIRST Robotics Competition robot for many thousands of eyes to see. We place the organization's name on team t-shirts, we display the organization's name or logo on this website, and we give them a shout-out on our social media.",
  },
  {
    name: "Builder sponsors",
    level: "Mid level",
    amount: "$500+ annual contribution",
    icon: "lucide:hammer",
    description:
      "Triple Helix celebrates our relationship with these sponsors by displaying the sponsoring organization's name or logo on this website and giving them a shout-out on our social media.",
  },
  {
    name: "Spark sponsors",
    level: "Entry level",
    amount: "$200+ annual contribution",
    icon: "lucide:zap",
    description:
      "Triple Helix celebrates our relationship with these sponsors by giving the sponsoring organization a shout-out on our social media.",
  },
];
---

<Base
  title="Support Us — Triple Helix Robotics"
  description="Support Triple Helix Robotics through donations, sponsorship, in-kind contributions, or volunteer service."
>
  <Nav />

  <main>
    <!-- Intro -->
    <section class="max-w-5xl mx-auto px-4 py-16">
      <h1 class={`${h1} mb-8`}>We welcome new supporters and collaborators</h1>
      <p class="text-gray-600 mb-6">
        Triple Helix has been a consistent leader in advocating for STEM
        education on the Virginia Peninsula, and we are seeking major corporate
        sponsors and new community partnerships to bolster our ambitious efforts
        to create lasting positive change. We need your help to develop the next
        generation of engineers, scientists, and technologists.
      </p>
    </section>

    <!-- Ways to support -->
    <section class="bg-gray-100 py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class={h2}>Ways to support us</h2>
        <p class="text-gray-600 mb-8">
          Triple Helix is an all-volunteer program whose success depends on
          community support. All forms of support are deeply valued:
        </p>
        <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 mb-8">
          <div class={`text-center ${card} p-6`}>
            <Icon
              name="lucide:package"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class={h3}>In-kind contributions</h3>
            <p class="text-sm text-gray-600">
              In-kind donations of parts, materials, and tools are used to
              advance our capabilities and boost the educational experience for
              our students.{" "}
              <a
                href={`${import.meta.env.BASE_URL}publications/2019-09-20-in-kind-donation-most-wanted-list/`}
                class={link}
              >
                See our most-wanted list.
              </a>
            </p>
          </div>
          <div class={`text-center ${card} p-6`}>
            <Icon
              name="lucide:banknote"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class={h3}>Financial support</h3>
            <p class="text-sm text-gray-600">
              Monetary donations fund team infrastructure — tools, equipment,
              and the resources our students need to compete.
            </p>
          </div>
          <div class={`text-center ${card} p-6`}>
            <Icon
              name="lucide:heart"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class={h3}>Service</h3>
            <p class="text-sm text-gray-600">
              Donations of service hours enrich our program by helping us form
              exciting connections in our community, and bring valuable new
              perspectives to our team processes.
            </p>
          </div>
          <div class={`text-center ${card} p-6`}>
            <Icon
              name="lucide:building-2"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class={h3}>Matching gifts</h3>
            <p class="text-sm text-gray-600">
              Many employers match charitable donations or volunteer hours —
              sometimes doubling your contribution at no extra cost to you.{" "}
              <a
                href="https://www.charitynavigator.org/donor-basics/giving-101/employee-match-programs/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-watermelon hover:text-gold transition-colors"
              >
                Learn more
                <Icon
                  name="lucide:external-link"
                  class="w-3 h-3 shrink-0"
                  aria-hidden="true"
                />
              </a>
            </p>
          </div>
        </div>
        <div class="flex justify-center">
          <a
            href="https://www.paypal.com/donate?hosted_button_id=R9BJ2TLELQR6W"
            target="_blank"
            rel="noopener noreferrer"
            class={btn}
          >
            Donate now
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
          </a>
        </div>
        <p class="mt-6 text-gray-600">
          By offsetting our internal costs, financial support extends our
          ability to make lasting positive contributions to the community we
          serve. Triple Helix solicits tax-deductible monetary donations through
          our operating sponsor{" "}
          <a href="https://www.iifound.org/" class={link}>
            Intentional Innovation Foundation</a
          >, a Newport News 501(c)(3) tax-exempt public charity.
        </p>
        <p class="mt-3 text-gray-600">
          Wishing to contribute to Triple Helix by another method? Please{" "}
          <a href={`${import.meta.env.BASE_URL}contact/`} class={link}
            >contact us</a
          >{" "}
          for more information on how you can get involved.
        </p>
      </div>
    </section>

    <!-- Sponsorship tiers -->
    <section class="bg-white py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class={`${h2} text-center`}>Sponsorship tiers</h2>
        <div class="flex flex-col gap-6">
          {
            sponsorshipTiers.map(
              ({ name, level, amount, icon, description }) => (
                <div class="rounded-lg border-2 border-gray-200 shadow-md hover:shadow-lg transition-shadow overflow-hidden grid grid-cols-[1fr_3fr]">
                  <div class="bg-purple px-5 py-6 flex flex-col items-center justify-center gap-2 text-center">
                    <Icon
                      name={icon}
                      class="w-6 h-6 text-gold"
                      aria-hidden="true"
                    />
                    <h3 class="font-bold text-white">{name}</h3>
                  </div>
                  <div class="bg-white px-5 py-6">
                    <p class="text-sm font-semibold text-purple mb-2">
                      {level} — {amount}
                    </p>
                    <p class="text-sm text-gray-600">{description}</p>
                  </div>
                </div>
              ),
            )
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
