---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import sponsorsData from "./sponsors.json";

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  "./sponsor-logos/*.{png,jpg,jpeg,webp,svg}",
  { eager: true },
);

function getLogo(filename: string): ImageMetadata | undefined {
  return logoModules[`./sponsor-logos/${filename}`]?.default;
}

const sponsorshipTiers = [
  {
    name: "Visionary partners",
    level: "Elite level",
    amount: "$10,000+ annual contribution",
    icon: "lucide:gem",
    description:
      "Triple Helix celebrates our relationship with these strategic and founding partners by displaying the sponsoring organization's logo on the team's competition robot, the organization's name on team t-shirts, and the organization's name or logo on this website, along with a shout-out at competition and social media recognition.",
  },
  {
    name: "Innovation sponsors",
    level: "Premium level",
    amount: "$1,500+ annual contribution",
    icon: "lucide:lightbulb",
    description:
      "Triple Helix celebrates our relationship with these major sponsors by displaying the sponsoring organization's logo on the team's FIRST Robotics Competition robot for many thousands of eyes to see. We place the organization's name on team t-shirts, we display the organization's name or logo on this website, and we give them a shout-out on our social media.",
  },
  {
    name: "Builder sponsors",
    level: "Mid level",
    amount: "$500+ annual contribution",
    icon: "lucide:hammer",
    description:
      "Triple Helix celebrates our relationship with these sponsors by displaying the sponsoring organization's name or logo on this website and giving them a shout-out on our social media.",
  },
  {
    name: "Spark sponsors",
    level: "Entry level",
    amount: "$200+ annual contribution",
    icon: "lucide:zap",
    description:
      "Triple Helix celebrates our relationship with these sponsors by giving the sponsoring organization a shout-out on our social media.",
  },
];
---

<Base
  title="Partners — Triple Helix Robotics"
  description="The sponsors and partners who make Triple Helix Robotics possible."
>
  <Nav />

  <main>
    <!-- Intro -->
    <section class="max-w-4xl mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold text-purple mb-8">
        Our relationship with our sponsors
      </h1>
      <p class="text-gray-600 mb-6">
        Our sponsors are integral parts of Triple Helix and help form the team's
        identity. Their support extends far beyond monetary donations. Several
        sponsors provide the team with mentors and advisors, others assist in
        part production or provide in-kind donation of services or materials,
        and others provide volunteers during major Triple Helix events.
      </p>
      <p class="text-gray-600 mb-6">
        Our sponsors are true partners. Through our work together, we aim to
        effect a fundamental change that enables our youth a greater access to
        STEM as a possible career choice. This perspective resonated strongly
        with judges at a recent competition, who stated:
      </p>
      <blockquote class="border-l-4 border-gold pl-6 my-6 text-gray-600 italic">
        This year's Chairman's Award winner embodies the definition of an
        influencer. They're a powerful and compelling force that impacts
        mentors, corporations, local governments, and school boards who are now
        embracing the values of FIRST and STEM in their communities.
      </blockquote>
      <p class="text-gray-600">
        To be competitive in the FIRST Robotics Competition is a significant
        undertaking that requires sustained sponsorship from multiple large
        funding sources, as well as sustained involvement of volunteer mentors.
        More than a dozen engineers, designers, software developers, and other
        technical professionals engage with Triple Helix students in hundreds of
        contact hours each year. Students team up with these mentors to solve
        challenging competitive long-term technical projects with real
        requirements and constraints, ultimately winning recognition, gaining
        self-confidence, developing people and life skills, making new friends,
        and discovering an unforeseen career path and a lifetime love of STEM.
      </p>
    </section>

    <!-- Our partners -->
    <section class="bg-gray-100 py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-purple mb-12 text-center">
          Our partners
        </h2>

        {
          sponsorsData.tiers.map(({ name, sponsors }) => {
            const logoSize =
              name === "Strategic & founding partners"
                ? { px: 160, cls: "w-40 h-40" }
                : name === "Major sponsors"
                  ? { px: 120, cls: "w-[120px] h-[120px]" }
                  : { px: 80, cls: "w-20 h-20" };
            return (
              <div class="mb-12">
                <h3 class="text-xl font-bold text-purple mb-6 border-b border-gray-200 pb-2 text-center">
                  {name}
                </h3>
                <ul class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
                  {sponsors.map(({ name: sponsorName, url, logo }) => {
                    const src = getLogo(logo);
                    return (
                      <li>
                        <a
                          href={url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex flex-col items-center gap-2 p-3 rounded border border-gray-200 bg-white hover:border-gold hover:shadow-sm transition-all group w-full h-full"
                          title={sponsorName}
                        >
                          {src ? (
                            <Image
                              src={src}
                              alt={sponsorName}
                              width={logoSize.px}
                              height={logoSize.px}
                              class={`${logoSize.cls} object-contain`}
                              loading="lazy"
                            />
                          ) : (
                            <span
                              class={`${logoSize.cls} flex items-center justify-center text-xs text-gray-400`}
                            >
                              {sponsorName}
                            </span>
                          )}
                          <span class="text-xs text-center text-gray-500 group-hover:text-gray-600 transition-colors">
                            {sponsorName}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          })
        }

        <!-- We also thank -->
        <div>
          <h3
            class="text-xl font-bold text-purple mb-4 border-b border-gray-200 pb-2 text-center"
          >
            We also thank
          </h3>
          <ul class="flex flex-wrap gap-x-8 gap-y-3 justify-center">
            {
              sponsorsData.weAlsoThank.map((name) => (
                <li class="text-sm text-gray-600">{name}</li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- Become a donor -->
    <section id="become-a-donor" class="bg-purple text-white py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8">Become a donor</h2>
        <p class="text-gray-300 mb-4">
          Triple Helix has been a consistent leader in advocating for STEM
          education on the Virginia Peninsula, and we are seeking major
          corporate sponsors and new community partnerships to bolster our
          ambitious efforts to create lasting positive change. We need your help
          to develop the next generation of engineers, scientists, and
          technologists.
        </p>
        <p class="text-gray-300 mb-8">
          Triple Helix is an all-volunteer program whose success depends on
          community support. All forms of support are deeply valued:
        </p>
        <div class="grid gap-6 sm:grid-cols-3 mb-8">
          <div class="text-center">
            <Icon
              name="lucide:package"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class="font-bold text-gold mb-2">In-kind contributions</h3>
            <p class="text-sm text-gray-300">
              In-kind donations of parts, materials, and tools are used to
              advance our capabilities and boost the educational experience for
              our students.
            </p>
          </div>
          <div class="text-center">
            <Icon
              name="lucide:banknote"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class="font-bold text-gold mb-2">Financial support</h3>
            <p class="text-sm text-gray-300">
              Funds amplify the team's existing resources and are used to pay
              for team infrastructure including tools and equipment. By
              offsetting these internal costs, this support extends our ability
              to make lasting positive contributions to the community we serve.
            </p>
          </div>
          <div class="text-center">
            <Icon
              name="lucide:heart"
              class="w-7 h-7 text-gold mb-2 mx-auto"
              aria-hidden="true"
            />
            <h3 class="font-bold text-gold mb-2">Service</h3>
            <p class="text-sm text-gray-300">
              Donations of service hours enrich our program by helping us form
              exciting connections in our community, and bring valuable new
              perspectives to our team processes.
            </p>
          </div>
        </div>
        <a
          href="https://www.paypal.com/donate?hosted_button_id=R9BJ2TLELQR6W"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-fit mx-auto bg-gold text-purple font-bold px-6 py-3 rounded hover:bg-yellow-400 transition-colors"
        >
          Donate now
        </a>
      </div>
    </section>

    <!-- Sponsorship tiers -->
    <section class="bg-gray-100 py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-purple mb-12 text-center">
          Sponsorship tiers
        </h2>
        <div class="flex flex-col gap-6">
          {
            sponsorshipTiers.map(
              ({ name, level, amount, icon, description }) => (
                <div class="rounded shadow-sm overflow-hidden grid grid-cols-[1fr_3fr]">
                  <div class="bg-purple px-5 py-6 flex flex-col items-center justify-center gap-2 text-center">
                    <Icon
                      name={icon}
                      class="w-6 h-6 text-gold"
                      aria-hidden="true"
                    />
                    <h3 class="font-bold text-white">{name}</h3>
                  </div>
                  <div class="bg-white px-5 py-6">
                    <p class="text-sm font-semibold text-purple mb-2">
                      {level} — {amount}
                    </p>
                    <p class="text-sm text-gray-600">{description}</p>
                  </div>
                </div>
              ),
            )
          }
        </div>
        <p class="mt-10 text-sm text-gray-600 max-w-lg mx-auto">
          Triple Helix solicits tax-deductible monetary donations through our
          operating sponsor{" "}
          <a
            href="https://www.iifound.org/"
            class="text-watermelon hover:text-gold transition-colors"
          >
            Intentional Innovation Foundation</a
          >, a Newport News 501(c)(3) tax-exempt public charity.
        </p>
        <p class="mt-3 text-sm text-gray-600 max-w-lg mx-auto">
          Wishing to contribute to Triple Helix by another method? Please{" "}
          <a
            href={`${import.meta.env.BASE_URL}contact/`}
            class="text-watermelon hover:text-gold transition-colors"
            >contact us</a
          >{" "}
          for more information on how you can get involved.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>
