---
import { Icon } from "astro-icon/components";

const socialLinks = [
  {
    label: "YouTube",
    icon: "simple-icons:youtube",
    href: "https://www.youtube.com/@TripleHelix2363",
  },
  {
    label: "Facebook",
    icon: "simple-icons:facebook",
    href: "https://www.facebook.com/TripleHelix2363",
  },
  {
    label: "Instagram",
    icon: "simple-icons:instagram",
    href: "https://www.instagram.com/triplehelix2363/",
  },
  {
    label: "GitHub",
    icon: "simple-icons:github",
    href: "https://github.com/TripleHelixProgramming",
  },
  {
    label: "LinkedIn",
    icon: "simple-icons:linkedin",
    href: "https://www.linkedin.com/company/intentional-innovation-foundation/",
  },
];

const resourceLinks = [
  {
    label: "Team Calendar",
    icon: "lucide:calendar",
    href: "http://calendar.team2363.org",
  },
  {
    label: "Team Handbook",
    icon: "lucide:book-open",
    href: "http://handbook.team2363.org",
  },
];

const year = new Date().getFullYear();
---

<footer class="bg-navy-dark text-white">
  <div class="max-w-6xl mx-auto px-4 pt-12 pb-8">
    <!-- Brand row -->
    <div class="mb-8">
      <p class="text-gold font-bold text-lg">Triple Helix Robotics</p>
    </div>

    <!-- 3-column grid -->
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Get in touch -->
      <div>
        <h2 class="font-bold mb-4">Get in touch</h2>
        <ul class="space-y-2">
          <li>
            <a
              href="https://maps.app.goo.gl/Y2VosW3wmbiVZwp48"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-gray-300 hover:text-gold transition-colors"
            >
              <Icon
                name="lucide:map-pin"
                class="w-4 h-4 shrink-0"
                aria-hidden="true"
              />
              Peninsula STEM Gym
            </a>
          </li>
          <li>
            <a
              href={`${import.meta.env.BASE_URL}contact/`}
              class="flex items-center gap-2 text-sm text-gray-300 hover:text-gold transition-colors"
            >
              <Icon
                name="lucide:mail"
                class="w-4 h-4 shrink-0"
                aria-hidden="true"
              />
              Contact us
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h2 class="font-bold mb-4">Resources</h2>
        <ul class="space-y-2">
          {
            resourceLinks.map(({ label, icon, href }) => (
              <li>
                <a
                  href={href}
                  class="flex items-center gap-2 text-sm text-gray-300 hover:text-gold transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon
                    name={icon}
                    class="w-4 h-4 shrink-0"
                    aria-hidden="true"
                  />
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h2 class="font-bold mb-4">Follow us</h2>
        <ul class="space-y-2">
          {
            socialLinks.map(({ label, icon, href }) => (
              <li>
                <a
                  href={href}
                  class="flex items-center gap-2 text-sm text-gray-300 hover:text-gold transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon
                    name={icon}
                    class="w-4 h-4 shrink-0"
                    aria-hidden="true"
                  />
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-navy px-4 py-4 text-center text-xs text-gray-500">
    © {year} Triple Helix Robotics
  </div>
</footer>
