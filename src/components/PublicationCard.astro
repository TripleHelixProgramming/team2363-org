---
// A publication card for use in a horizontal carousel.
// Renders a <div> — place directly inside a <Carousel>.
//
// Usage
//   <Carousel>
//     {publications.map((pub) => <PublicationCard pub={pub} />)}
//   </Carousel>

import { Image } from "astro:assets";
import { excerpt } from "../utils/excerpt";
import type { CollectionEntry } from "astro:content";

interface Props {
  pub: CollectionEntry<"publications">;
}

const { pub } = Astro.props;
const { title, date, links, thumbnail } = pub.data;
const slug = pub.id.replace(/\/index\.md$/, "");
---

<div
  class="shrink-0 snap-start w-80 bg-white rounded-lg border-2 border-gray-200 shadow-md p-5"
>
  {
    thumbnail && (
      <Image
        src={thumbnail}
        alt=""
        class="w-full h-40 object-cover rounded mb-4"
      />
    )
  }
  <p class="text-xs text-gray-400 mb-1">
    {
      date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
    }
  </p>
  <h3 class="font-bold text-purple mb-2">
    <a
      href={`${import.meta.env.BASE_URL}publications/${slug}/`}
      class="hover:text-gold transition-colors"
    >
      {title}
    </a>
  </h3>
  {pub.body && <p class="text-sm text-gray-600 mb-3">{excerpt(pub.body)}</p>}
  {
    links && links.length > 0 && (
      <ul class="flex flex-wrap gap-2">
        {links.map(({ label, url }) => (
          <li>
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-xs font-medium text-watermelon hover:text-gold"
            >
              {label}
              <svg
                class="w-3 h-3"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</div>
