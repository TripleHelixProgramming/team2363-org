---
// Rendered as a single static element — @click must not be inside any JS
// conditional expression or Prettier will mangle it. Alpine guards behavior.
interface Props {
  heading: string;
  expandable: boolean;
  paragraphs: string[];
}

const { heading, expandable, paragraphs } = Astro.props;

// Paragraphs prefixed with "> " are rendered as blockquotes.
const blocks = paragraphs.map((p) =>
  p.startsWith("> ")
    ? { type: "blockquote", text: p.slice(2) }
    : { type: "p", text: p },
);
---

<div
  x-data={`{ open: false, expandable: ${expandable} }`}
  @click="if (expandable) open = !open"
  :class="expandable ? 'cursor-pointer hover:bg-gray-50' : ''"
  class="border-2 border-gray-200 rounded-lg overflow-hidden transition-colors"
  :role="expandable ? 'button' : undefined"
  :tabindex="expandable ? 0 : undefined"
  :aria-expanded="expandable ? open : undefined"
>
  <div class="flex items-center gap-3 px-5 py-4">
    <svg
      class="w-5 h-5 flex-shrink-0 transition-transform duration-200"
      :class="expandable ? (open ? 'rotate-90 text-gray-500' : 'text-gray-400') : 'opacity-0'"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
    <h2 class="text-lg font-bold text-purple">{heading}</h2>
  </div>
  <div
    x-show="expandable && open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="px-5 pb-5 border-t border-gray-100"
    style="display: none"
  >
    <div class="pt-4 space-y-4">
      {
        blocks.map((block) =>
          block.type === "blockquote" ? (
            <blockquote class="border-l-4 border-gold pl-4 text-gray-500 leading-relaxed">
              {block.text}
            </blockquote>
          ) : (
            <p class="text-gray-600 leading-relaxed">{block.text}</p>
          ),
        )
      }
    </div>
  </div>
</div>
