---
import AccordionItem from "./AccordionItem.astro";

interface Item {
  heading: string;
  body?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="my-8 flex flex-col gap-3">
  {
    items.map((item) => (
      <AccordionItem
        heading={item.heading}
        expandable={!!item.body?.trim()}
        paragraphs={item.body?.trim().split(/\n\n+/) ?? []}
      />
    ))
  }
</div>
