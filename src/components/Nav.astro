---
const links = [
  { label: "Home", href: "/" },
  { label: "About", href: "/#about" },
  { label: "Partners", href: "/partners/" },
  { label: "Publications", href: "/publications/" },
  { label: "Contact", href: "/contact/" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 bg-navy-dark text-white"
  x-data="{ open: false }"
>
  <nav
    class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="font-bold text-lg text-gold hover:text-white transition-colors"
    >
      Triple Helix Robotics
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex gap-6 text-sm font-medium">
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                "hover:text-gold transition-colors",
                currentPath === href ? "text-gold" : "text-white",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu button -->
    <button
      class="md:hidden p-2 rounded hover:bg-navy transition-colors"
      aria-label="Toggle menu"
      @click="open = !open"
      :aria-expanded="open"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          x-show="!open"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
        <path
          x-show="open"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div x-show="open" x-transition class="md:hidden bg-navy px-4 pb-4">
    <ul class="flex flex-col gap-3 text-sm font-medium">
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="block py-1 hover:text-gold transition-colors"
              @click="open = false"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
