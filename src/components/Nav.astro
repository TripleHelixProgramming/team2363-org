---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const base = import.meta.env.BASE_URL;
const links = [
  { label: "Home", href: base },
  { label: "About", href: `${base}#about` },
  { label: "Partners", href: `${base}partners/` },
  { label: "Publications", href: `${base}publications/` },
  { label: "Contact", href: `${base}contact/` },
];

const currentPath = Astro.url.pathname;
---

<header
  class:list={[
    "sticky top-0 z-50 text-white transition-colors duration-300",
    !transparent && "bg-purple",
  ]}
  x-data={transparent
    ? "{ open: false, scrolled: window.scrollY > 10, mobile: window.innerWidth < 768 }"
    : "{ open: false }"}
  {...transparent
    ? {
        "@scroll.window": "scrolled = window.scrollY > 10",
        "@resize.window": "mobile = window.innerWidth < 768",
        ":class":
          "(scrolled || open || mobile) ? 'bg-purple' : 'bg-transparent'",
      }
    : {}}
  x-init="$watch('open', val => document.body.style.overflow = val ? 'hidden' : '')"
>
  <nav
    class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href={base}
      class="font-bold text-lg text-white hover:text-gold transition-colors"
    >
      Triple Helix Robotics
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex gap-6 text-sm font-medium">
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                "hover:text-gold transition-colors",
                currentPath === href ? "text-gold" : "text-white",
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile menu button -->
    <button
      class="md:hidden p-2 rounded hover:bg-navy transition-colors"
      aria-label="Toggle menu"
      @click="open = !open"
      :aria-expanded="open"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          x-show="!open"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
        <path
          x-show="open"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    x-show="open"
    x-transition
    class="md:hidden absolute top-full -mt-px left-0 right-0 bg-purple px-4 pb-4"
  >
    <ul class="flex flex-col gap-3 text-sm font-medium items-end">
      {
        links.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                "block py-1 hover:text-gold transition-colors",
                currentPath === href ? "text-gold" : "text-white",
              ]}
              @click="open = false"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
